# YouTube Data API v3 key (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=

# Twitter/X Bearer Token (https://developer.twitter.com/en/portal — needs Basic plan $100/mo)
TWITTER_BEARER_TOKEN=

# LLM backend: "ollama" (default, free local) or "openai"
LLM_BACKEND=ollama
OLLAMA_MODEL=llama3
# OpenAI-compatible API key (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
